{
  "analysis": {
    "maxFiles": 500,
    "batchSize": 50,
    "maxFileSize": 102400,
    "batchDelay": 1000,
    "targetDir": "./app",
    "ignore": ["**/node_modules/**", "**/dist/**", "**/build/**"]
  },
  "lighthouse": {
    "port": 3000,
    "mobileEmulation": false,
    "throttling": {
      "cpu": 4,
      "network": "4G"
    }
  },
  "output": {
    "format": "md",
    "directory": "./reports",
    "filename": "performance-analysis",
    "includeTimestamp": true
  },
  "ai": {
    "model": "claude-opus-4-8",
    "maxTokens": 16000
  }
}
